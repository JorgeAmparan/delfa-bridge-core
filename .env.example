# ── Required ─────────────────────────────────────────────────────────────────

# JWT — MUST be set, no default (min 32 chars recommended)
JWT_SECRET=your-strong-random-secret-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated, NO wildcard
ALLOWED_ORIGINS=https://app.panohayan.com,http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Google Gemini (LLM provider)
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional (dev only) ─────────────────────────────────────────────────────

# Dev API key — only set if you need X-API-Key auth for development
# API_KEY=your-dev-api-key

# Org ID
ORG_ID=your_org_id
DATA_DIR=./data

# ── BGE-M3 Embeddings (self-hosted) ─────────────────────────────────────────

BGE_M3_URL=http://localhost:8080
BGE_M3_TIMEOUT=30

# ── FalkorDB ─────────────────────────────────────────────────────────────────

FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=panohayan

# ── Redis ────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# ── SQL Connector (optional) ────────────────────────────────────────────────

SQL_DB_TYPE=mysql
SQL_HOST=localhost
SQL_PORT=3306
SQL_DATABASE=nombre_bd
SQL_USER=usuario
SQL_PASSWORD=password
# SQL_CONNECTION_STRING=dialect+driver://user:pass@host/db

# ── MicroSip (optional) ─────────────────────────────────────────────────────

MICROSIP_URL=http://servidor:5000
MICROSIP_USER=usuario
MICROSIP_PASSWORD=password
MICROSIP_DB=ip:/microsip

# ── Stripe (optional) ───────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
