# ── Required ─────────────────────────────────────────────────────────────────

# JWT — MUST be set, no default (min 32 chars recommended)
JWT_SECRET=your-strong-random-secret-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated, NO wildcard
ALLOWED_ORIGINS=https://app.docyan.com,http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── LLMs de INGESTA (GraphRAG-SDK vía LiteLLM — B1) ──────────────────────────
# Extracción + Resolution: Gemini 2.5 Flash. El prefijo `gemini/` es OBLIGATORIO
# en el model string (gemini/gemini-2.5-flash); sin él LiteLLM defaultea a
# Vertex AI y falla pidiendo credenciales GCP. Variable GEMINI_API_KEY (NO GOOGLE_API_KEY).
GEMINI_API_KEY=your_gemini_api_key_here
# QA / consulta del pipeline de ingesta: gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# ── LLMs de TRADUCCIÓN (Pista A, vía Model Router) ───────────────────────────
# Claude Sonnet 4.6 (+ Gemini 2.5 Pro). Tier medio piloto.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional (dev only) ─────────────────────────────────────────────────────

# Dev API key — only set if you need X-API-Key auth for development
# API_KEY=your-dev-api-key

# Org ID
ORG_ID=your_org_id
DATA_DIR=./data

# ── BGE-M3 Embeddings (self-hosted) ─────────────────────────────────────────

BGE_M3_URL=http://localhost:8080
BGE_M3_TIMEOUT=30

# ── FalkorDB ─────────────────────────────────────────────────────────────────

FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=docyan

# ── Redis ────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379/0

# ── SQL Connector (optional) ────────────────────────────────────────────────

SQL_DB_TYPE=mysql
SQL_HOST=localhost
SQL_PORT=3306
SQL_DATABASE=nombre_bd
SQL_USER=usuario
SQL_PASSWORD=password
# SQL_CONNECTION_STRING=dialect+driver://user:pass@host/db

# ── MicroSip (optional) ─────────────────────────────────────────────────────

MICROSIP_URL=http://servidor:5000
MICROSIP_USER=usuario
MICROSIP_PASSWORD=password
MICROSIP_DB=ip:/microsip

# ── Stripe (optional) ───────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
