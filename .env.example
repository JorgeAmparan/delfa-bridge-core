# =============================================================================
# DOCYAN LDE™ by XCID — variables de entorno (fuente de verdad)
# -----------------------------------------------------------------------------
# Separadas por proceso de Fly (topología de 5 apps, CLAUDE.md §3):
#   - docyan-lde-api      → BACKEND (este bloque "BACKEND")
#   - docyan-lde-ingest   → WORKER de ingesta (bloque "WORKER")
#   - docyan-lde-graph    → FalkorDB (sin .env; volumen)
#   - docyan-lde-embedder → BGE-M3 (ver embedder/)
#   - docyan-lde-redis    → Redis (ver redis/)
#
# En PRODUCCIÓN, los valores marcados [SECRET] se fijan con `flyctl secrets set`
# (ver docs/runbook_secrets_produccion.md). Los marcados [ENV] van en `[env]`
# del fly.toml correspondiente (no sensibles). Este archivo es solo plantilla
# local — NUNCA commitear un .env real (gitleaks corre en CI).
# =============================================================================


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ BACKEND — docyan-lde-api                                                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# JWT_SECRET [SECRET] — OBLIGATORIO, sin default (mín. 32 chars). Falla loud si falta.
JWT_SECRET=your-strong-random-secret-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# [SECRET en prod] comma-separated, NO wildcard.
ALLOWED_ORIGINS=https://app.docyan.com,http://localhost:3000

# ── Supabase (PostgreSQL + Storage + Auth) ───────────────────────────────────
# CRÍTICO. Sin estos secrets, TODO endpoint que toque EDB/GRG/FAT/documents/
# governance/billing/auth falla con RuntimeError loud (B0.6). Fuente de los
# valores: Supabase Dashboard → Project Settings → API.
#   - SUPABASE_URL          [SECRET] = Project URL
#   - SUPABASE_KEY          [SECRET] = anon / public key (usado por edb, grg,
#                                      matrix, documents, governance, billing,
#                                      mcp_server). RLS aplicado.
#   - SUPABASE_SERVICE_KEY  [SECRET] = service_role key (SOLO auth.py; bypass RLS).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── LLMs de INGESTA (GraphRAG-SDK vía LiteLLM — B1) ──────────────────────────
# Extracción + Resolution: Gemini 2.5 Flash. El prefijo `gemini/` es OBLIGATORIO
# en el model string (gemini/gemini-2.5-flash); sin él LiteLLM defaultea a
# Vertex AI y falla pidiendo credenciales GCP. Variable GEMINI_API_KEY (NO GOOGLE_API_KEY).
GEMINI_API_KEY=your_gemini_api_key_here          # [SECRET]
# QA / consulta del pipeline de ingesta: gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here          # [SECRET]

# ── LLMs de TRADUCCIÓN (Pista A, vía Model Router) ───────────────────────────
# Claude Sonnet 4.6 (+ Gemini 2.5 Pro). Tier medio piloto.
ANTHROPIC_API_KEY=your_anthropic_api_key_here    # [SECRET]
# Override opcional del Model Router (solo dev/debug).
# MR_OVERRIDE_MODEL=

# ── BGE-M3 Embeddings (self-hosted, docyan-lde-embedder) ─────────────────────
# EMBEDDER_URL es la variable canónica (BGE_M3_URL es compat). Ambas [ENV].
# En prod van en fly.toml [env]; en local apuntan a localhost.
EMBEDDER_URL=http://localhost:8080
BGE_M3_URL=http://localhost:8080
BGE_M3_TIMEOUT=30

# ── FalkorDB (DKG + DTM, docyan-lde-graph) ───────────────────────────────────
# FALKOR_HOST/FALKOR_PORT son canónicas (FALKORDB_* son compat). [ENV] en prod.
FALKOR_HOST=localhost
FALKOR_PORT=6379
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=docyan
FALKOR_QUERY_TIMEOUT_MS=10000

# ── Redis (sesiones MO/APScheduler B4 + cola de ingesta B2) ──────────────────
# REDIS_URL [SECRET en prod] — sesiones / scheduler.
# REDIS_QUEUE_URL [SECRET en prod] — cola de ingesta (la usa el cotizador del
#   backend para encolar y el worker para consumir). En prod ambas apuntan a
#   docyan-lde-redis.internal:6379.
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6379/0

# ── Org / data ───────────────────────────────────────────────────────────────
ORG_ID=your_org_id
DATA_DIR=./data

# ── Dev API key (opcional, solo desarrollo) ──────────────────────────────────
# Solo setear si necesitas auth por X-API-Key en desarrollo.
# API_KEY=your-dev-api-key

# ── Stripe (billing — opcional) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                    # [SECRET]
STRIPE_WEBHOOK_SECRET=whsec_...                  # [SECRET]
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── WhatsApp 360dialog (B9 — aún no cableado en código) ──────────────────────
# WA_360DIALOG_API_KEY=                           # [SECRET]
# WA_360DIALOG_WEBHOOK_SECRET=                    # [SECRET]

# ── Conectores / ingest_sources (NO foco MVP — opcionales) ───────────────────
# SQL connector
SQL_DB_TYPE=mysql
SQL_HOST=localhost
SQL_PORT=3306
SQL_DATABASE=nombre_bd
SQL_USER=usuario
SQL_PASSWORD=password
# SQL_CONNECTION_STRING=dialect+driver://user:pass@host/db
# Microsoft Graph (OneDrive/SharePoint)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=                            # [SECRET]
# AZURE_TENANT_ID=
# ONEDRIVE_USER_ID=
# FTP / SFTP
# FTP_HOST=
# FTP_PORT=21
# FTP_USER=
# FTP_PASSWORD=                                   # [SECRET]
# FTP_PROTOCOL=ftp
# Notion
# NOTION_TOKEN=                                   # [SECRET]
# Google Drive (service account o OAuth)
# GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_CREDENTIALS_FILE=
# LangExtract (puenteado desde GEMINI_API_KEY si no se setea; ver dii.py)
# LANGEXTRACT_API_KEY=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ WORKER — docyan-lde-ingest                                                 ║
# ║ (Construido en B2; vive en worker/. NO usa Supabase: solo Docling +       ║
# ║  GraphRAG-SDK + FalkorDB + LLM. El cotizador/Supabase está en el BACKEND.)║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Secrets del worker (flyctl secrets set --app docyan-lde-ingest):
#   GEMINI_API_KEY        [SECRET] — extracción/resolution (mismo valor que backend)
#   OPENAI_API_KEY        [SECRET] — QA gpt-4o-mini
#   REDIS_QUEUE_URL       [SECRET] — cola de la que consume jobs
#
# [ENV] del worker (ya en worker/fly.toml, NO son secrets):
#   FALKOR_HOST=docyan-lde-graph.internal
#   FALKOR_PORT=6379
#   EMBEDDER_URL=http://docyan-lde-embedder.internal:8000
#   HF_HUB_OFFLINE=1
#   TRANSFORMERS_OFFLINE=1
#   DOCLING_ARTIFACTS_PATH=/root/.cache/docling/models
#
# Opcionales del worker:
#   WORKER_POP_TIMEOUT=5         # timeout del BLPOP de la cola (segundos)
#   INGEST_STORAGE_DIR=          # dir de artefactos de ingesta si aplica
